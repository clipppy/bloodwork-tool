<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.bloodwork-tool.ui</string>

    <key>ProgramArguments</key>
    <array>
        <string>bash</string>
        <string>-lc</string>
        <string>cd /Users/USERNAME/Documents/bloodwork-tool &amp;&amp; npm run ui</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/USERNAME/Documents/bloodwork-tool</string>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/tmp/bloodwork-tool.log</string>

    <key>StandardErrorPath</key>
    <string>/tmp/bloodwork-tool.error.log</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin</string>
    </dict>
</dict>
</plist>
